{
  "rewrites": [
    { "source": "/",             "destination": "/index.html" },
    { "source": "/login",        "destination": "/index.html" },
    { "source": "/ambassador",   "destination": "/ambassador.html" },
    { "source": "/dashboard",    "destination": "/dashboard.html" },
    { "source": "/staff",        "destination": "/staff.html" },
    { "source": "/bookings",     "destination": "/bookings.html" },
    { "source": "/leaderboard",  "destination": "/leaderboard.html" },
    { "source": "/activity",     "destination": "/activity.html" },
    { "source": "/profile",      "destination": "/profile.html" },
    { "source": "/checkin",      "destination": "/checkin.html" },
    { "source": "/credits",      "destination": "/credits.html" },
    { "source": "/power-night",  "destination": "/power-night.html" },
    { "source": "/admin",        "destination": "/admin.html" },
    { "source": "/super-admin",  "destination": "/super-admin.html" },
    { "source": "/vip",          "destination": "/vip.html" },
    { "source": "/vip-login",    "destination": "/vip-login.html" },
    { "source": "/vip-apply",    "destination": "/vip-apply.html" },
    { "source": "/vip-setup",    "destination": "/vip-setup.html" },
    { "source": "/vip-reset",    "destination": "/vip-reset.html" },
    { "source": "/vip-profile",  "destination": "/vip-profile.html" },
    { "source": "/amb-login",    "destination": "/amb-login.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-monthly-spend",
      "schedule": "0 2 1 * *"
    },
    {
      "path": "/api/cron-streak",
      "schedule": "0 8 * * 0"
    },
    {
      "path": "/api/sync-social",
      "schedule": "0 */6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
